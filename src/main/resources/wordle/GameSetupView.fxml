<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="wordle.GameSetupController">

    <center>
        <StackPane>
            <VBox  spacing="10" style="-fx-padding: 10;" prefWidth="200.0">
                <Label fx:id="titleLabel" text="Select difficulty"/>
                <HBox fx:id="wordTypeBox" spacing="5">
                    <Label text="Select"/>
                    <ComboBox fx:id="wordTypeOptions"/>

                    <Label fx:id="statusLabel" text=""/>
                    <Button text="Start" onAction="#launchGame"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>


</BorderPane>